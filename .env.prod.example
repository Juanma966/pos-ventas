# Variables para docker-compose.prod.yml
# Copiar a .env y completar con valores reales:  cp .env.prod.example .env
# (Para dar de alta clientes con varios stacks en un mismo host, usá
#  scripts/nuevo-cliente.sh, que genera un .env por cliente automáticamente.)

# Prefijo de los contenedores y el volumen (identificador del stack/cliente).
STACK_NAME=pos

# --- Base de datos (Postgres) ---
POSTGRES_DB=pos_ventas
POSTGRES_USER=pos_user
POSTGRES_PASSWORD=cambiar_por_password_seguro

# --- Secretos JWT ---
# OBLIGATORIO en producción: 32+ caracteres y NO los valores de ejemplo.
# Generar con:  openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Frontend / CORS ---
# URL pública desde donde se sirve el frontend (para CORS del backend).
FRONTEND_URL=http://localhost
# Puerto HTTP público (nginx del frontend)
HTTP_PORT=80
